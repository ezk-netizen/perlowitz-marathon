{
  "compilerOptions": {
    "types": [
      "astro/client"
    ],
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve"
  },
  "include": [
    ".astro/types.d.ts",
    "**/*.ts",
    "**/*.astro"
  ],
  "exclude": [
    "node_modules"
  ]
}
