{
  "name": "marathon-registration",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "start": "astro dev",
    "preview": "astro build && wrangler pages dev dist",
    "deploy": "astro build && wrangler pages deploy dist --project-name perlowitz-marathon",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.2",
    "astro": "^5.16.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "25.7.0",
    "typescript": "^5.6.2",
    "wrangler": "^4.90.1"
  }
}
